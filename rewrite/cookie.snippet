# hostname
hostname = api.m.jd.com, auth.aliyundrive.com, c.tieba.baidu.com, me-api.jd.com, ms.jr.jd.com

# aliyundrive
^https?:\/\/auth\.aliyundrive\.com\/v2\/account\/token url script-response-body https://github.com/lowking/Scripts/raw/master/ali/aliYunPanCheckIn.js

# jd_dailybonus
^https?:\/\/(api\.m|me-api)\.jd\.com\/(client\.action\?functionId=signBean|user_new\/info\/GetJDUserInfoUnion\?) url script-request-header https://github.com/NobyDa/Script/raw/master/JD-DailyBonus/JD_DailyBonus.js
^https?:\/\/ms\.jr\.jd\.com\/gw\/generic\/hy\/h5\/m\/appSign\? url script-request-body https://github.com/NobyDa/Script/raw/master/JD-DailyBonus/JD_DailyBonus.js

# tieba
^https?:\/\/c\.tieba\.baidu\.com\/c\/s\/login url script-request-header https://github.com/Larkris/earth/raw/main/script/tieba.js
